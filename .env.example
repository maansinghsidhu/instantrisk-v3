# InstantRisk V2 - Environment Variables
# Copy this file to .env and fill in your values


# Application Settings
APP_NAME=InstantRisk
APP_VERSION=5.0.0
DEBUG=False
ENVIRONMENT=production

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
SECRET_KEY=

# Database Settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=instantrisk_admin
POSTGRES_PASSWORD=
POSTGRES_DB=instantrisk

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=

# Qdrant Vector Database Settings
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=instantrisk_documents

# S3 Object Storage Settings
S3_DOCUMENTS_BUCKET=instantrisk-documents-995306061991
S3_RAPIDRATE_BUCKET=instantrisk-rapidrate-995306061991
S3_REGION=us-east-1

# RapidRate Lambda Settings
RAPIDRATE_LAMBDA_NAME=instantrisk-rapidrate
RAPIDRATE_LAMBDA_REGION=us-east-1

# JWT Settings
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI Settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# AWS Bedrock Settings
AWS_BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_FALLBACK_MODEL=us.anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_ENABLED=True

# ClaimSense Settings
CLAIMSENSE_API_URL=https://vgyk08rvg4.execute-api.us-east-1.amazonaws.com/ucop-db-genai-insights-lambda
CLAIMSENSE_ENABLED=True

# File Upload Settings
MAX_UPLOAD_SIZE=52428800
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=/tmp/uploads

# Logging
LOG_LEVEL=INFO

# SMTP Settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@instantrisk.com

# Lloyd's Data
LLOYDS_SYNDICATE_DATA_PATH=./data/syndicates/lloyds_2025.json

# Google Cloud Settings
GOOGLE_APPLICATION_CREDENTIALS=

# Security Settings
SECURITY_LOG_PATH=/tmp/security.log

# CAPTCHA Settings (mCaptcha)
MCAPTCHA_URL=http://localhost:7000
MCAPTCHA_SITE_KEY=
MCAPTCHA_SECRET_KEY=
CAPTCHA_ENABLED=False

# Rate Limiting
RATE_LIMIT_ENABLED=True

# Circuit Breaker Thresholds
CIRCUIT_BREAKER_HOURLY_AI_LIMIT=500
CIRCUIT_BREAKER_DAILY_COST_LIMIT_CENTS=10000
