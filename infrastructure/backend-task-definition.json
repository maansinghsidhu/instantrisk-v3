{
  "family": "instantrisk-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::995306061991:role/instantrisk-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::995306061991:role/instantrisk-backend-task-role",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "995306061991.dkr.ecr.us-east-1.amazonaws.com/instantrisk-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "ENVIRONMENT", "value": "production"},
        {"name": "DATABASE_HOST", "value": "instantrisk-db.cyjui2sqceiw.us-east-1.rds.amazonaws.com"},
        {"name": "DATABASE_PORT", "value": "5432"},
        {"name": "DATABASE_NAME", "value": "instantrisk"},
        {"name": "DATABASE_USER", "value": "instantrisk_admin"},
        {"name": "REDIS_HOST", "value": "instantrisk-redis.mudo3b.0001.use1.cache.amazonaws.com"},
        {"name": "REDIS_PORT", "value": "6379"},
        {"name": "QDRANT_HOST", "value": "qdrant.instantrisk.local"},
        {"name": "QDRANT_PORT", "value": "6334"},
        {"name": "S3_DOCUMENTS_BUCKET", "value": "instantrisk-documents-995306061991"},
        {"name": "S3_RAPIDRATE_BUCKET", "value": "instantrisk-rapidrate-995306061991"},
        {"name": "S3_REGION", "value": "us-east-1"},
        {"name": "BEDROCK_REGION", "value": "us-east-1"},
        {"name": "RAPIDRATE_LAMBDA_NAME", "value": "instantrisk-rapidrate"}
      ],
      "secrets": [
        {
          "name": "DATABASE_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:995306061991:secret:instantrisk/database-3KNa2l:password::"
        },
        {
          "name": "SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:995306061991:secret:instantrisk/app-secret-GVs197"
        },
        {
          "name": "JWT_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:995306061991:secret:instantrisk/jwt-secret-25GkUZ"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/instantrisk-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "backend"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/api/v1/health/live || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
